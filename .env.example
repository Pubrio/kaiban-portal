# ---------------------------------------------------------------------------
# Which LLM backend the KaibanJS build crew uses: "anthropic" or "bedrock"
# ---------------------------------------------------------------------------
LLM_PROVIDER=bedrock

# --- Option A: Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# --- Option B: AWS Bedrock (this demo's default) ---
# Credentials come from the standard AWS provider chain (env vars below,
# ~/.aws/credentials, SSO, or an IAM role).
AWS_REGION=ap-southeast-1
# Any Bedrock model id / inference profile you have access to. Nova is not
# geo-restricted; Claude-on-Bedrock is blocked from some regions. For Qwen use
# a qwen.* id in us-west-2 / us-east-1 / ap-northeast-1.
BEDROCK_MODEL=apac.amazon.nova-lite-v1:0
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

PORT=3000
