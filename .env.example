# --- LLM backend ---
LLM_PROVIDER=bedrock
AWS_REGION=ap-northeast-1
BEDROCK_MODEL=qwen.qwen3-32b-v1:0
# AWS creds — get these from the workshop host (do NOT commit real values)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# --- Portal ---
WORKSHOP_PASSWORD=kaiban-demo        # gate for write actions
HITL_DEFAULT=on                      # human Q&A approval gate (on|off), also toggleable in UI
# PORT is set automatically by most hosts; locally defaults to 4000

# --- Optional: publish the built app back to GitHub ---
# GITHUB_TOKEN=ghp_xxx               # fine-grained token with contents:write
# PUBLISH_REPO=Pubrio/todo-list-app
